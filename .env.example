# Healthcare Data MCP — Environment Variables
# Copy to .env and fill in the keys you need.
# Servers that need no keys work out of the box.

# ── Geo-Demographics Server (port 8003) ──────────────────────────────────────
# Census Bureau API key (free: https://api.census.gov/data/key_signup.html)
CENSUS_API_KEY=
# HUD USPS Crosswalk API token (free: https://www.huduser.gov/portal/dataset/uspszip-api.html)
HUD_API_TOKEN=

# ── Drive-Time Server (port 8004) ────────────────────────────────────────────
# OpenRouteService API key for isochrones (free: https://openrouteservice.org/dev/#/signup)
ORS_API_KEY=
# OSRM base URL (optional, defaults to public demo server)
OSRM_BASE_URL=http://router.project-osrm.org

# ── Financial Intelligence Server (port 8008) ────────────────────────────────
# SEC EDGAR User-Agent (REQUIRED — server will refuse to start without it)
# Format: "YourAppName your-real-email@domain.com"
# SEC blocks requests with generic/placeholder User-Agents.
# See: https://www.sec.gov/os/accessing-edgar-data
SEC_USER_AGENT=

# ── Workforce Analytics Server (port 8011) ───────────────────────────────────
# Bureau of Labor Statistics API key (free: https://data.bls.gov/registrationEngine/)
BLS_API_KEY=

# ── Public Records Server (port 8013) ────────────────────────────────────────
# SAM.gov Entity API key (free: https://sam.gov/content/entity-information)
SAM_GOV_API_KEY=
# ONC CHPL API key (free: https://chpl.healthit.gov/#/resources/api)
CHPL_API_KEY=

# ── Web Intelligence Server (port 8014) ──────────────────────────────────────
# Google Custom Search API key (https://developers.google.com/custom-search/v1/overview)
GOOGLE_CSE_API_KEY=
# Google Custom Search Engine ID
GOOGLE_CSE_ID=
# Proxycurl API key for LinkedIn data (https://nubela.co/proxycurl)
PROXYCURL_API_KEY=
