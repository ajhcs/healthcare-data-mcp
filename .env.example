# Healthcare Data MCP environment template.
# Generated from shared.utils.server_registry via scripts/render_env_example.py.
# Leave optional keys blank. Do not put PHI, SSNs, EINs, TINs, or patient data here.

# Optional API keys, public source limits, and local imports
# Optional Census key for higher API limits.
CENSUS_API_KEY=
# Optional HUD USPS ZIP crosswalk API token.
HUD_API_TOKEN=
# Optional OpenRouteService key for isochrones.
ORS_API_KEY=
# Optional OSRM endpoint; defaults to the public demo server.
OSRM_BASE_URL=http://router.project-osrm.org
# Optional BLS key for higher API limits.
BLS_API_KEY=
# Optional normalized ACGME Program Search export path.
ACGME_PROGRAMS_CSV=
# Optional licensed CareSet DocGraph import path.
DOCGRAPH_CSV_PATH=
# Required for SAM.gov opportunity and Exclusions API tools.
SAM_GOV_API_KEY=
# Optional ONC CHPL enrichment key.
CHPL_API_KEY=
# Optional Google Custom Search API key.
GOOGLE_CSE_API_KEY=
# Optional Google Custom Search Engine ID.
GOOGLE_CSE_ID=
# Google Custom Search per-session request guardrail.
GOOGLE_CSE_SESSION_LIMIT=40
# Google Custom Search cache TTL in seconds.
GOOGLE_CSE_CACHE_TTL_SECONDS=21600
# Google Custom Search daily request guardrail.
GOOGLE_CSE_DAILY_LIMIT=100
# Optional Proxycurl enrichment key.
PROXYCURL_API_KEY=
# Optional CDC PLACES cache directory override.
PLACES_CACHE_DIR=
# Maximum ClinicalTrials.gov records scanned by inventory tools.
CLINICAL_TRIALS_INVENTORY_HARD_MAX=5000

# SEC EDGAR User-Agent
# Required for financial-intelligence SEC EDGAR-backed tools.
# Format: YourAppName your-real-email@domain.com
SEC_USER_AGENT=

# Local launcher and client helpers
# Docker Compose sets MCP_HOST=0.0.0.0 inside containers while published ports bind to 127.0.0.1.
HC_MCP_ENV_FILE=
MCP_HOST=127.0.0.1

# Remote metadata gateway
# Leave auth disabled for local-only development.
# For production, terminate HTTPS at a reverse proxy and prefer SHA-256 token hashes.
# Whether metadata gateway HTTP/SSE auth is required.
MCP_GATEWAY_AUTH_REQUIRED=false
# Optional local bearer token.
MCP_GATEWAY_BEARER_TOKEN=
# Comma-separated metadata gateway bearer tokens.
MCP_GATEWAY_BEARER_TOKENS=
# Recommended token hash for remote deployments.
MCP_GATEWAY_BEARER_TOKEN_SHA256=
# Comma-separated metadata gateway bearer token SHA-256 hashes.
MCP_GATEWAY_BEARER_TOKEN_SHA256_LIST=
# Required metadata gateway auth scopes; defaults to mcp:read.
MCP_GATEWAY_REQUIRED_SCOPES=mcp:read
# Optional semicolon-separated SHA-256 token-hash scope overrides.
MCP_GATEWAY_TOKEN_SCOPES=
# Allowed Host headers for metadata gateway HTTP/SSE.
MCP_GATEWAY_ALLOWED_HOSTS=localhost:8016,127.0.0.1:8016
# Allowed Origin headers for metadata gateway HTTP/SSE.
MCP_GATEWAY_ALLOWED_ORIGINS=http://localhost:*,http://127.0.0.1:*
# Public HTTPS MCP URL for metadata gateway deployments.
MCP_GATEWAY_PUBLIC_URL=
# OAuth/OIDC issuer URL advertised by the metadata gateway.
MCP_GATEWAY_ISSUER_URL=

# Authenticated live gateway
# HTTP/SSE requires auth by default. Add mcp:bulk only for deployments that should expose batch screening.
# Prefer MCP_LIVE_GATEWAY_TOKEN_SCOPES=<sha256>=mcp:read+mcp:bulk for selected bulk-screening tokens.
# Global mcp:bulk is rejected unless MCP_LIVE_GATEWAY_ALLOW_GLOBAL_BULK_SCOPE=true.
# MCP_LIVE_GATEWAY_ALLOW_NETWORK_BIND=true also requires HTTPS public URL and explicit Host/Origin allow-lists.
# Whether live-gateway HTTP/SSE auth is required; cannot disable remote auth.
MCP_LIVE_GATEWAY_AUTH_REQUIRED=true
# Bearer token for live HTTP/SSE deployments.
MCP_LIVE_GATEWAY_BEARER_TOKEN=
# Comma-separated live-gateway bearer tokens.
MCP_LIVE_GATEWAY_BEARER_TOKENS=
# Recommended token hash for live HTTP/SSE deployments.
MCP_LIVE_GATEWAY_BEARER_TOKEN_SHA256=
# Comma-separated live-gateway bearer token SHA-256 hashes.
MCP_LIVE_GATEWAY_BEARER_TOKEN_SHA256_LIST=
# Required auth scopes; defaults to mcp:read.
MCP_LIVE_GATEWAY_REQUIRED_SCOPES=mcp:read
# Optional semicolon-separated SHA-256 token-hash scope overrides; use this to grant mcp:bulk to selected tokens.
MCP_LIVE_GATEWAY_TOKEN_SCOPES=
# Explicit opt-in to grant mcp:bulk to every valid live-gateway token.
MCP_LIVE_GATEWAY_ALLOW_GLOBAL_BULK_SCOPE=false
# Docker-only marker for container wildcard binds published to localhost.
MCP_LIVE_GATEWAY_CONTAINER_LOCAL_BIND=false
# Explicit opt-in for live-gateway wildcard network binds behind HTTPS and locked allow-lists.
MCP_LIVE_GATEWAY_ALLOW_NETWORK_BIND=false
# Allowed Host headers for live-gateway HTTP/SSE.
MCP_LIVE_GATEWAY_ALLOWED_HOSTS=localhost:8020,127.0.0.1:8020
# Allowed Origin headers for live-gateway HTTP/SSE.
MCP_LIVE_GATEWAY_ALLOWED_ORIGINS=http://localhost:*,http://127.0.0.1:*
# Public HTTPS MCP URL for live-gateway deployments.
MCP_LIVE_GATEWAY_PUBLIC_URL=
# OAuth/OIDC issuer URL advertised by live-gateway.
MCP_LIVE_GATEWAY_ISSUER_URL=
# Optional JSONL file path for non-secret live-gateway audit events.
MCP_LIVE_GATEWAY_AUDIT_LOG_PATH=

# Price transparency download guardrails
# Maximum hospital MRF download size in bytes.
MRF_MAX_DOWNLOAD_BYTES=10737418240
# Minimum free disk bytes required before MRF downloads.
MRF_MIN_FREE_BYTES=2147483648
# Progress logging interval for large MRF downloads.
MRF_DOWNLOAD_PROGRESS_INTERVAL_BYTES=104857600
