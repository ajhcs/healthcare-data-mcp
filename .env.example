# Census Bureau API key (free: https://api.census.gov/data/key_signup.html)
CENSUS_API_KEY=

# HUD USPS Crosswalk API token (free: https://www.huduser.gov/portal/dataset/uspszip-api.html)
HUD_API_TOKEN=

# OpenRouteService API key for isochrones (free: https://openrouteservice.org/dev/#/signup)
ORS_API_KEY=

# Bureau of Labor Statistics API key (optional, improves workforce analytics limits)
BLS_API_KEY=

# SAM.gov and CHPL API keys for public-records enrichment
SAM_GOV_API_KEY=
CHPL_API_KEY=

# Google Custom Search and Proxycurl keys for web-intelligence
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_ID=
PROXYCURL_API_KEY=

# OSRM base URL (optional, defaults to public demo server)
# For self-hosted: http://localhost:5000
OSRM_BASE_URL=http://router.project-osrm.org

# Optional explicit dotenv path for stdio clients launched outside the repo root.
# Most users should leave this unset; pass it in client config when needed.
HC_MCP_ENV_FILE=

# MCP HTTP bind host. Local runs default to 127.0.0.1.
# Docker Compose sets MCP_HOST=0.0.0.0 inside containers so published ports work.
MCP_HOST=127.0.0.1

# Remote metadata gateway. Leave auth disabled for local-only development.
# For production, terminate HTTPS at a reverse proxy and set a SHA-256 token hash.
MCP_GATEWAY_AUTH_REQUIRED=false
MCP_GATEWAY_BEARER_TOKEN_SHA256=
MCP_GATEWAY_REQUIRED_SCOPES=mcp:read
MCP_GATEWAY_ALLOWED_HOSTS=localhost:8016,127.0.0.1:8016
MCP_GATEWAY_ALLOWED_ORIGINS=http://localhost:*,http://127.0.0.1:*
MCP_GATEWAY_PUBLIC_URL=
MCP_GATEWAY_ISSUER_URL=

# SEC EDGAR User-Agent (REQUIRED — server will refuse to start without it)
# Format: "YourAppName your-real-email@domain.com"
# SEC blocks requests with generic/placeholder User-Agents.
# See: https://www.sec.gov/os/accessing-edgar-data
SEC_USER_AGENT=
